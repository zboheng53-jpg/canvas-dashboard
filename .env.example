# Canvas Dashboard does not require environment variables for local use.
# This is a reference file; set overrides in the process environment.
# Production systemd reads /etc/canvas-dashboard/canvas-dashboard.env.

# Local defaults
CANVAS_DASHBOARD_HOST=127.0.0.1
CANVAS_DASHBOARD_PORT=5000
CANVAS_DASHBOARD_COOKIE_SECURE=0
CANVAS_DASHBOARD_ICP_NUMBER=
CANVAS_DASHBOARD_APPLE_CALENDAR_ENABLED=0
CANVAS_DASHBOARD_MAX_CONTENT_LENGTH_BYTES=8388608

# Optional term fallback
TONGJI_TERM_LABEL=2025-2026学年 第二学期
TONGJI_TERM_START=2026-03-02

# Optional 智慧树 supervisor override
ZHIHUISHU_FETCH_TIMEOUT_SECONDS=180

# Runtime data stays in ./data and must never be committed.
# The app creates ./data/.flask_secret_key and ./data/.encryption_key automatically.
