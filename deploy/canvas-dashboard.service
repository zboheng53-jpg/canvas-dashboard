[Unit]
Description=Canvas Dashboard (Flask/Waitress)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/canvas-dashboard
Environment=ZHIHUISHU_CHROMIUM_EXECUTABLE=/usr/bin/google-chrome-stable
ExecStart=/home/ubuntu/canvas-dashboard/.venv/bin/python serve.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
